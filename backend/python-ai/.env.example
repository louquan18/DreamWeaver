# DreamWeaver AI Service - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# App
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://dreamweaver:dreamweaver@localhost:5432/dreamweaver

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM / OpenRouter
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Model routing (optional overrides)
# MODEL_PLANNER=anthropic/claude-sonnet-4-20250514
# MODEL_WRITER=anthropic/claude-sonnet-4-20250514
# MODEL_CONSISTENCY=openai/gpt-4o-mini
# MODEL_REVIEWER=anthropic/claude-sonnet-4-20250514

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
