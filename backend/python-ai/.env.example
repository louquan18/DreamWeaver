# DreamWeaver AI Service - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# App
DEBUG=true

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dreamweaver:dreamweaver@localhost:5432/dreamweaver

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Chroma (向量数据库)
# ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ──────────────────────────────────────────────
# LLM - OpenRouter 多模型聚合（OpenAI 兼容接口）
# 一个 LLM_API_KEY（OpenRouter Key）即可调度下方所有模型
# 也可改 LLM_BASE_URL 指向其他兼容网关 / 本地 vLLM
# ──────────────────────────────────────────────
LLM_API_KEY=your-openrouter-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter 推荐请求头（用量归因，可留空）
OPENROUTER_REFERER=
OPENROUTER_TITLE=DreamWeaver

# 各 Agent 模型路由（混合策略）。slug 以 https://openrouter.ai/models 为准。
# 主模型 + fallback 备用模型（主模型在产出 token 前失败时自动切换）
# Stage-level model routing. Leave blank to fall back to the legacy keys below.
MODEL_BLUEPRINT=
MODEL_BLUEPRINT_FALLBACK=
MODEL_OUTLINE=
MODEL_OUTLINE_FALLBACK=
MODEL_DRAFT=
MODEL_DRAFT_FALLBACK=
MODEL_CONSISTENCY=openai/gpt-4o-mini
MODEL_CONSISTENCY_FALLBACK=deepseek/deepseek-chat
MODEL_REVIEW=
MODEL_REVIEW_FALLBACK=
MODEL_REPAIR=
MODEL_REPAIR_FALLBACK=
MODEL_MEMORY_EXTRACT=
MODEL_MEMORY_EXTRACT_FALLBACK=

# Legacy agent-level model routing, kept as backwards-compatible fallback.
MODEL_PLANNER=anthropic/claude-3.5-sonnet
MODEL_PLANNER_FALLBACK=openai/gpt-4o
MODEL_WRITER=anthropic/claude-3.5-sonnet
MODEL_WRITER_FALLBACK=deepseek/deepseek-chat
MODEL_REVIEWER=anthropic/claude-3.5-sonnet
MODEL_REVIEWER_FALLBACK=openai/gpt-4o
MODEL_REWRITE=anthropic/claude-3.5-sonnet
MODEL_REWRITE_FALLBACK=openai/gpt-4o
MODEL_CONTEXT=deepseek/deepseek-chat
MODEL_CONTEXT_FALLBACK=openai/gpt-4o-mini

# ──────────────────────────────────────────────
# Object Storage (OSS) - 可选
# ──────────────────────────────────────────────
# OSS_ENDPOINT=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=dreamweaver
