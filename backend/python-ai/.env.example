# DreamWeaver AI Service - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# App
DEBUG=true

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dreamweaver:dreamweaver@localhost:5432/dreamweaver

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Chroma (向量数据库)
# ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ──────────────────────────────────────────────
# LLM - OpenAI 兼容接口
# 支持: 小米 MiMo / OpenRouter / 硅基流动 / 本地 vLLM 等
# ──────────────────────────────────────────────
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1

# 各 Agent 使用的模型 ID（按需修改）
MODEL_PLANNER=mimo-7b
MODEL_WRITER=mimo-7b
MODEL_CONSISTENCY=mimo-7b
MODEL_REVIEWER=mimo-7b
MODEL_REWRITE=mimo-7b
MODEL_CONTEXT=mimo-7b

# ──────────────────────────────────────────────
# Object Storage (OSS) - 可选
# ──────────────────────────────────────────────
# OSS_ENDPOINT=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=dreamweaver
